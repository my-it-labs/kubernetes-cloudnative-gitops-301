{
  "name": "Kubernetes CloudNative GitOps Lab",
  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
      "version": "latest",
      "helm": "latest",
      "minikube": "none"
    }
  },
  "postCreateCommand": "chmod +x scripts/*.sh && bash scripts/bootstrap-tools.sh && cp --update=none infra/.env.example infra/.env 2>/dev/null || true",
  "forwardPorts": [8080, 8081, 9080, 3000, 9090],
  "portsAttributes": {
    "8080": { "label": "Demo Web", "onAutoForward": "notify" },
    "8081": { "label": "Demo API", "onAutoForward": "notify" },
    "9080": { "label": "Kind ingress", "onAutoForward": "silent" },
    "3000": { "label": "Grafana (M08)", "onAutoForward": "silent" },
    "9090": { "label": "Prometheus (M08)", "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "redhat.vscode-yaml",
        "vscjava.vscode-java-pack",
        "angular.ng-template"
      ]
    }
  }
}
